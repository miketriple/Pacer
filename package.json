{
  "name": "pacer",
  "version": "1.0.0",
  "private": true,
  "description": "Guided rhythm for any workflow",
  "type": "module",
  "scripts": {
    "build":     "node build.cjs",
    "cap:sync":  "node build.cjs && cap sync android",
    "cap:run":   "node build.cjs && cap run android",
    "cap:open":  "cap open android",
    "test":      "node --test \"test/**/*.test.js\""
  },
  "dependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@capacitor/android": "^8.0.0"
  }
}
